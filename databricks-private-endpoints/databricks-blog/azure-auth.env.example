# Azure Service Principal Credentials for Terraform
# Copy this to azure-auth.env and fill in your values
# NEVER commit azure-auth.env to version control

export ARM_CLIENT_ID="YOUR-CLIENT-ID"
export ARM_CLIENT_SECRET="YOUR-CLIENT-SECRET"
export ARM_TENANT_ID="YOUR-TENANT-ID"

# Environment-specific subscription IDs
export ARM_SUBSCRIPTION_ID_DEV="YOUR-DEV-SUBSCRIPTION-ID"
export ARM_SUBSCRIPTION_ID_TEST="YOUR-TEST-SUBSCRIPTION-ID"
export ARM_SUBSCRIPTION_ID_STAGE="YOUR-STAGE-SUBSCRIPTION-ID"
export ARM_SUBSCRIPTION_ID_ANALYTICS="YOUR-ANALYTICS-SUBSCRIPTION-ID"
export ARM_SUBSCRIPTION_ID_POC="YOUR-POC-SUBSCRIPTION-ID"

export ARM_SUBSCRIPTION_ID="YOUR-DEFAULT-SUBSCRIPTION-ID"
